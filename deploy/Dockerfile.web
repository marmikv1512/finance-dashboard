FROM node:20-bookworm-slim

WORKDIR /app

RUN corepack enable && corepack prepare pnpm@10.33.0 --activate

COPY . .

RUN pnpm install --no-frozen-lockfile

ENV BASE_PATH=/

RUN pnpm --filter @workspace/finance-tracker run build

RUN npm install -g serve

CMD ["sh", "-c", "serve -s artifacts/finance-tracker/dist/public -l ${PORT:-3000}"]